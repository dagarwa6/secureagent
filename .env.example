# ============================================================
# SecureAgent Environment Variables
# All LLM providers listed here are FREE to sign up
# ============================================================

# ----- PRIMARY LLM: Groq (FREE) -----
# Sign up at https://console.groq.com — no credit card required
# Free tier: 14,400 requests/day, 30 req/min
GROQ_API_KEY=gsk_your_key_here

# ----- FALLBACK LLM: Google Gemini (FREE) -----
# Sign up at https://aistudio.google.com — no credit card required
# Free tier: 15 req/min, 1M tokens/min
GEMINI_API_KEY=your_gemini_key_here

# ----- LLM Model Selection -----
GROQ_MODEL=llama-3.1-70b-versatile
GEMINI_MODEL=gemini-1.5-flash

# ----- Paths -----
CORPUS_PATH=corpus/
FRAMEWORK_PATH=data/frameworks/
CHROMA_DB_PATH=data/indices/chroma_db
OUTPUT_PATH=output/

# ----- LangSmith (Optional, for agent tracing — free tier available) -----
# Sign up at https://smith.langchain.com — free for personal use
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls_your_key_here
# LANGCHAIN_PROJECT=secureagent
